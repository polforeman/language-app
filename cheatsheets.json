  "cases": {
    "russian": {
      "title": "Grammatical Cases",
      "content": [
        "**The 6 Cases:**",
        "• **Nominative (Subject):** Кто/что (e.g., вода)",
        "• **Accusative (Direct Object):** Кого/что (e.g., его, вижу книгу)",
        "• **Genitive (Possession/'of'/'from'):** Кого/чего (e.g., мальчика, из города)",
        "• **Dative (Indirect Object/'to'):** Кому/чему (e.g., сестре, учителю)",
        "• **Instrumental (Means/'with'):** Кем/чем (e.g., ручкой, с братом)",
        "• **Prepositional (Location/'about'):** О ком/о чём (e.g., в школе, о работе)"
      ]
    },
    "ukrainian": {
      "title": "Grammatical Cases",
      "content": [
        "**The 7 Cases (Common 6):**",
        "• **Nominative (Subject):** Хто/що (e.g., вода)",
        "• **Accusative (Direct Object):** Кого/що (e.g., його, бачу книгу)",
        "• **Genitive (Possession/'of'/'from'):** Кого/чого (e.g., хлопчика, з міста)",
        "• **Dative (Indirect Object/'to'):** Кому/чому (e.g., сестрі, вчителеві)",
        "• **Instrumental (Means/'with'):** Ким/чим (e.g., ручкою, з братом)",
        "• **Locative (Location/'about'):** На кому/на чому (e.g., у школі, про роботу)"
      ]
    },
    "portuguese": {
      "title": "Grammatical Cases (Contractions & Pronouns)",
      "content": [
        "**Preposition Contractions:**",
        "• **de + articles (Genitive equivalent):**",
        "  • de + o = do | de + a = da | de + os/as = dos/das",
        "• **em + articles (Locative/Prepositional):**",
        "  • em + o = no | em + a = na | em + os/as = nos/nas",
        "• **a + articles (Dative equivalent):**",
        "  • a + o = ao | a + a = à | a + os/as = aos/às",
        "",
        "**Object Pronouns (Accusative/Dative):**",
        "• Direct object: -o, -a (e.g., vejo-o)",
        "• Indirect object: -lhe (e.g., dou-lhe a chave)",
        "• Us object: -nos (e.g., ajuda-nos)"
      ]
    },
    "german": {
      "title": "Grammatical Cases",
      "content": [
        "**The 4 Cases & Definite Articles:**",
        "• **Nominative (Subject):** der, die, das, die",
        "• **Accusative (Direct Object):** den, die, das, die",
        "• **Dative (Indirect Object):** dem, der, dem, den",
        "• **Genitive (Possession):** des (+s), der, des (+s), der",
        "",
        "**Preposition Rules:**",
        "• **Dative Only:** aus, bei, mit, nach, seit, von, zu (e.g., aus dem Restaurant, mit dem Hund)",
        "• **Accusative Only:** durch, für, gegen, ohne, um",
        "• **Two-Way (Wechsel):** in, auf, über (Accusative = movement, Dative = location)"
      ]
    }
  }
